# ─────────────────────────────────────────────────────────────────────
# EAI Capstone — Host Port Configuration
#
# Copy this file to .env and modify port numbers if any conflict
# with services already running on your machine.
#
# To apply changes: docker-compose down && docker-compose up -d --build
# ─────────────────────────────────────────────────────────────────────

# Node-RED editor and flow endpoints
NODERED_HOST_PORT=1880

# Business service ports (host-side only; internal ports are fixed)
ORDER_HOST_PORT=3001
PAYMENT_HOST_PORT=3002
INVENTORY_HOST_PORT=3003
NOTIFICATION_HOST_PORT=3004

# RabbitMQ (optional — uncomment the rabbitmq service in docker-compose.yml to use)
# RABBITMQ_AMQP_HOST_PORT=5672
# RABBITMQ_MGMT_HOST_PORT=15672
